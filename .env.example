# ── 對外 PORT（docker-compose port mapping 統一由此控管）────────
BACKEND_PORT=3001
WEB_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379

# ── 後端設定 ──────────────────────────────────────────────────
PORT=3001
DATABASE_URL=postgres://agent_flow:secret@localhost:5432/agent_flow?sslmode=disable
REDIS_URL=redis://localhost:6379
RUN_SEED=true
CLAUDE_TIMEOUT=10m
CLAUDE_DEFAULT_MAX_RETRIES=5
TASK_CONCURRENCY=1
ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173

# Gemini（選填，僅使用 Gemini Agent 時需設定）
GEMINI_API_KEY=

# ── 前端設定 ──────────────────────────────────────────────────
VITE_API_URL=/api

# ── Docker Compose（PostgreSQL）────────────────────────────────
POSTGRES_DB=agent_flow
POSTGRES_USER=agent_flow
POSTGRES_PASSWORD=secret
